PORT=5000
MONGODB_URI=mongodb://localhost:27017/back-on-track
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Encryption Key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=generate_a_256_bit_hex_key_using_the_command_above

# SSL/TLS Configuration (for production HTTPS)
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt

# Local Network Access
# In development (NODE_ENV=development), HTTP connections from local network are allowed
# This includes: localhost, 127.0.0.1, 192.168.x.x, 10.x.x.x, 172.16-31.x.x ranges
# In production, only HTTPS is enforced except from these local network ranges
