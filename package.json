{
  "name": "nocts-back-on-track",
  "version": "1.4.0",
  "description": "A Node.js application for tracking addictions",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "apk:local": "cd mobile && npm run apk:local",
    "apk:local:debug": "cd mobile && npm run apk:local:debug"
  },
  "keywords": [
    "addiction",
    "tracker",
    "motivation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "validator": "^13.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
