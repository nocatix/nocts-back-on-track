#!/bin/bash
# Pre-commit hook to prevent commits on main branch

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "main" ]; then
    echo "❌ ERROR: You are trying to commit to the 'main' branch directly."
    echo ""
    echo "✅ Please follow this workflow instead:"
    echo "   1. Create a topic branch: git checkout -b feature/your-feature-name"
    echo "   2. Make your changes and commit to your topic branch"
    echo "   3. Push your topic branch: git push origin feature/your-feature-name"
    echo "   4. Create a Pull Request on GitHub"
    echo "   5. After review, merge via Pull Request"
    echo ""
    echo "Current branch: $BRANCH"
    exit 1
fi

exit 0
